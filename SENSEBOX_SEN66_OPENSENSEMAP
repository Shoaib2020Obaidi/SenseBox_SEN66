void addMeasurement(const char *sensorId, float value) {
  if (num_measurements < NUM_SENSORS) {
    measurements[num_measurements].sensorId = sensorId;
    measurements[num_measurements].value = value;
    num_measurements++;
  }
}

void writeMeasurementsToClient() {
  for (uint8_t i = 0; i < num_measurements; i++) {
    sprintf_P(buffer, PSTR("%s,%9.2f\n"), measurements[i].sensorId, measurements[i].value);
    client.print(buffer);
  }
}

void submitValues() {
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("WiFi disconnected. Skipping upload.");
    return;
  }

  Serial.println("Connecting to openSenseMap...");
  client.setTimeout(10000);

  if (client.connect(server, 443)) {
    int content_length = num_measurements * 35; 

    sprintf_P(buffer, PSTR("POST /boxes/%s/data HTTP/1.1\nAuthorization: 17a9aa353da5849c0b50a7abe027e5ddafd02a32d72b066b5b71c40db2f2e8f7\nHost: %s\nContent-Type: text/csv\nConnection: close\nContent-Length: %i\n\n"),
              SENSEBOX_ID, server, content_length);
    
    client.print(buffer);
    writeMeasurementsToClient();
    client.println();

    unsigned long startWait = millis();
    while (client.connected() && millis() - startWait < 5000) {
        if (client.available()) {
          String line = client.readStringUntil('\n');
          if (line == "\r") break;
        }
    }
    client.stop();
    Serial.println("Data submitted successfully.");
  } else {
    Serial.println("Connection to server failed.");
  }
  
  num_measurements = 0; 
}

void setup() {
  Serial.begin(115200);
  Wire.begin();
  
  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3D)) {
    Serial.println(F("SSD1306 allocation failed"));
  }
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);
  display.setCursor(0,0);
  display.println("Initializing...");
  display.display();

  sensor.begin(Wire, SEN66_I2C_ADDR_6B);
  sensor.deviceReset();
  delay(1200);
  sensor.startContinuousMeasurement();

  WiFi.begin(ssid, pass);
  Serial.print("Connecting WiFi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi Connected");
  client.setCACert(root_ca);
}

void loop() {
  float pm1, pm25, pm4, pm10, hum, temp, voc, nox;
  uint16_t co2;

  // Read Sensor
  error = sensor.readMeasuredValues(pm1, pm25, pm4, pm10, hum, temp, voc, nox, co2);

  if (error == NO_ERROR) {
    // Accumulate values for averaging
    sum_pm25 += pm25;
    sum_pm10 += pm10;
    sum_temp += temp;
    sum_hum  += hum;
    sum_voc  += voc;
    sum_nox  += nox;
    sampleCount++;

    // Debug to Serial (Instant reading)
    Serial.printf("Live - Temp: %.1fC | PM2.5: %.1f | Samples: %d\n", temp, pm25, sampleCount);

    // Update Display
    display.clearDisplay();
    display.setCursor(0,0);
    display.printf("Temp: %.1f C\nHum:  %.1f %%\nPM2.5: %.1f\nSamples: %d", temp, hum, pm25, sampleCount);
    display.display();
  } else {
    errorToString(error, errorMessage, sizeof errorMessage);
    Serial.print("Sensor Error: ");
    Serial.println(errorMessage);
  }

  // Handle Timing for Upload (Every 60 Seconds)
  if (millis() - lastUploadTime >= uploadInterval && sampleCount > 0) {
    
    // Calculate Averages
    float avg_pm25 = sum_pm25 / sampleCount;
    float avg_pm10 = sum_pm10 / sampleCount;
    float avg_temp = sum_temp / sampleCount;
    float avg_hum  = sum_hum  / sampleCount;
    float avg_voc  = sum_voc  / sampleCount;
    float avg_nox  = sum_nox  / sampleCount;

    Serial.println("--- Uploading Averages ---");
    
    num_measurements = 0; 
    addMeasurement(SENSOR_IDA1B, avg_pm25);
    addMeasurement(SENSOR_IDA1C, avg_pm10);
    addMeasurement(SENSOR_IDA1D, avg_temp);
    addMeasurement(SENSOR_IDA1E, avg_hum);
    addMeasurement(SENSOR_IDA1F, avg_voc);
    addMeasurement(SENSOR_IDA20, avg_nox);
    
    submitValues();
    
    // Reset for next interval
    sum_pm25 = 0; sum_pm10 = 0; sum_temp = 0; sum_hum = 0; sum_voc = 0; sum_nox = 0;
    sampleCount = 0;
    lastUploadTime = millis();
  }

  delay(2000); 
}
